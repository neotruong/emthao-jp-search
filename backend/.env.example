PORT=8787
# Comma-separated list of allowed CORS origins. Defaults below cover Vite's primary
# port (5173) and its auto-fallback (5174) on both localhost and 127.0.0.1.
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
LOG_LEVEL=info
NODE_ENV=development

# ----- Optional local performance knobs (uncomment to override the code defaults) -----
# Code defaults are tuned for Render free (0.1 CPU / 512 MB). On a normal laptop you can
# get noticeably faster scrapes by relaxing them.
#
# Run all 3 scrapers in parallel (default 2 — Render free OOMs at 3 parallel Chromium tabs).
# SCRAPE_CONCURRENCY=3
#
# Per-scrape Playwright timeout. Local typically finishes in 2–4 s; 12000 ms is comfortable
# (default 20000 ms for Render headroom).
# SCRAPER_TIMEOUT_MS=12000
#
# In-memory cache TTL. Default 420000 ms (7 min). For local dev set to 86400000 (24 h) so
# repeating the same query never re-scrapes — the UI's "Refresh" button always bypasses
# the cache when you want fresh data.
# CACHE_TTL_MS=86400000
